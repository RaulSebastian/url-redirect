@page "/admin"
@model UrlRedirect.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin";
}

<div class="intro">
    <p class="eyebrow">RedirectApp <span class="version-badge">v1.1</span></p>
    <h1>admin console</h1>
    <p class="lede">Signed in as <strong>@Model.DisplayName</strong>. Review every redirect and remove entries when needed.</p>
</div>

<div class="card">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner status-success result-success">@Model.StatusMessage</div>
    }

    @if (Model.Redirects.Count == 0)
    {
        <p class="lede card-copy">No redirects have been created yet.</p>
    }
    else
    {
        <div class="table-wrap">
            <table class="redirect-table">
                <thead>
                <tr>
                    <th scope="col">Alias</th>
                    <th scope="col">Short URL</th>
                    <th scope="col">Target URL</th>
                    <th scope="col">Created</th>
                    <th scope="col">Action</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var redirect in Model.Redirects)
                {
                    <tr>
                        <td><code>@redirect.Alias</code></td>
                        <td><a href="@redirect.ShortUrl" target="_blank" rel="noopener">@redirect.ShortUrl</a></td>
                        <td><a href="@redirect.TargetUrl" target="_blank" rel="noopener">@redirect.TargetUrl</a></td>
                        <td>@redirect.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <form method="post" asp-page-handler="Delete" class="inline-form">
                                <input type="hidden" name="alias" value="@redirect.Alias" />
                                <button type="submit" class="button-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <div class="actions admin-actions">
        <a href="/ui" class="button-secondary">Open public UI</a>
        <a href="/auth/logout?returnUrl=/ui" class="button-secondary">Sign out</a>
    </div>
</div>
