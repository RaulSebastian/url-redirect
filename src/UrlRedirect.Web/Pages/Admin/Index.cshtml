@page "/admin"
@model UrlRedirect.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin";
}

<div class="intro">
    <p class="eyebrow">RedirectApp <span class="version-badge">v1.1</span></p>
    <h1>admin console</h1>
    <p class="lede">Signed in as <strong>@Model.DisplayName</strong>. Review every redirect and remove entries when needed.</p>
</div>

<div class="card">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status-banner status-success result-success">@Model.StatusMessage</div>
    }

    @if (Model.Redirects.Count == 0)
    {
        <p class="lede card-copy">No redirects have been created yet.</p>
    }
    else
    {
        <div class="admin-toolbar">
            <p class="table-summary">Showing @Model.Redirects.Count of @Model.TotalCount redirects</p>

            <form method="get" class="page-size-form">
                <input type="hidden" name="page" value="1" />
                <label for="page-size">Rows per page</label>
                <select id="page-size" name="pageSize" onchange="this.form.submit()">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="20" selected="@(Model.PageSize == 20)">20</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                </select>
            </form>
        </div>

        <div class="table-wrap">
            <table class="redirect-table">
                <thead>
                <tr>
                    <th scope="col">Alias</th>
                    <th scope="col">Short URL</th>
                    <th scope="col">Target URL</th>
                    <th scope="col">Created</th>
                    <th scope="col">Action</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var redirect in Model.Redirects)
                {
                    <tr>
                        <td><code>@redirect.Alias</code></td>
                        <td><a href="@redirect.ShortUrl" target="_blank" rel="noopener">@redirect.ShortUrl</a></td>
                        <td><a href="@redirect.TargetUrl" target="_blank" rel="noopener">@redirect.TargetUrl</a></td>
                        <td>@redirect.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <form method="post" asp-page-handler="Delete" class="inline-form">
                                <input type="hidden" name="alias" value="@redirect.Alias" />
                                <input type="hidden" name="page" value="@Model.CurrentPage" />
                                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                                <button type="submit" class="button-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <div class="admin-pagination">
            <a
                class="button-secondary pagination-link @(Model.HasPreviousPage ? string.Empty : "is-disabled")"
                asp-page="/Admin/Index"
                asp-route-page="@(Model.CurrentPage - 1)"
                asp-route-pageSize="@Model.PageSize"
                aria-disabled="@(!Model.HasPreviousPage)"
                tabindex="@(Model.HasPreviousPage ? "0" : "-1")">Previous</a>
            <p class="pagination-summary">Page @Model.CurrentPage of @Model.TotalPages</p>
            <a
                class="button-secondary pagination-link @(Model.HasNextPage ? string.Empty : "is-disabled")"
                asp-page="/Admin/Index"
                asp-route-page="@(Model.CurrentPage + 1)"
                asp-route-pageSize="@Model.PageSize"
                aria-disabled="@(!Model.HasNextPage)"
                tabindex="@(Model.HasNextPage ? "0" : "-1")">Next</a>
        </div>
    }

    <div class="actions admin-actions">
        <a href="/ui" class="button-secondary">Open public UI</a>
        <a href="/auth/logout?returnUrl=/ui" class="button-secondary">Sign out</a>
    </div>
</div>
