@page
@model UrlRedirect.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Create redirect";
}

<div class="intro">
    <p class="eyebrow">RedirectApp <span class="version-badge">v1.1</span></p>
    <h1>url redirect</h1>
    <p class="lede">Create a short, shareable redirect in seconds.</p>
</div>

<div class="card">
    <h2>New redirect</h2>

    <form id="redirect-form" novalidate>
        <div id="validation-summary" class="status-banner status-error" hidden></div>

        <div class="field">
            <label for="alias">Custom alias</label>
            <input id="alias" name="alias" autocomplete="off" placeholder="summer-sale"
                   pattern="^[a-z0-9][a-z0-9-_]{2,39}$" required />
            <span id="alias-error" class="field-error"></span>
            <small>3-40 characters: letters, digits, hyphens, underscores.</small>
        </div>

        <div class="field">
            <label for="target-url">Target URL</label>
            <input id="target-url" name="targetUrl" type="url" autocomplete="off"
                   placeholder="https://www.amazon.com/campaign?article=2454325" required />
            <span id="target-url-error" class="field-error"></span>
            <small>Must be a valid absolute URL.</small>
        </div>

        <div class="actions">
            <button type="submit" id="submit-button" class="button-primary">Create redirect</button>
        </div>
    </form>

    <div id="result-card" class="status-banner status-success result-success" aria-live="polite" hidden>
        <div class="result-summary">
            <div class="result-copy">
                <p class="result-label">Redirect created</p>
                <div class="result-link-row">
                    <a id="result-url" href="#" class="result-url" target="_blank" rel="noopener"></a>
                    <button type="button" id="show-qr-button" class="icon-button" aria-label="Show QR code" title="Show QR code">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M3 3h7v7H3V3Zm2 2v3h3V5H5Zm9-2h7v7h-7V3Zm2 2v3h3V5h-3ZM3 14h7v7H3v-7Zm2 2v3h3v-3H5Zm9-2h2v2h-2v-2Zm3 0h1v1h2v2h-2v1h3v3h-2v-1h-2v1h-2v-3h2v-1h-2v-2h2v-1Zm-3 3h1v1h-1v-1Zm3 3h1v1h-1v-1Z" />
                        </svg>
                    </button>
                </div>
            </div>
            <button type="button" id="copy-result-button" class="button-secondary result-copy-button">Copy short URL</button>
        </div>
    </div>
</div>

<div id="qr-modal" class="modal-backdrop" hidden>
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="qr-modal-title">
        <button type="button" id="close-qr-button" class="modal-close" aria-label="Close QR code">&times;</button>
        <p class="result-label">Scan to open</p>
        <h2 id="qr-modal-title">Redirect QR code</h2>
        <div class="qr-preview-shell">
            <img id="qr-code-image" alt="QR code for the created short URL" />
        </div>
        <a id="qr-modal-link" href="#" class="result-url" target="_blank" rel="noopener"></a>
    </div>
</div>

@section Scripts {
    <script src="/ui/assets/site.js" asp-append-version="true"></script>
}
