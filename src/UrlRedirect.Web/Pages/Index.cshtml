@page
@model UrlRedirect.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Create redirect";
}

<section class="hero">
    <div class="hero-copy">
        <p class="eyebrow">RedirectApp</p>
        <h1>URL Redirect</h1>
        <p class="lead">
            Create a short redirect in seconds.
        </p>
    </div>
</section>

<section class="panel">
    <div class="panel-header">
        <h2>New redirect</h2>
    </div>

    <form method="post" class="redirect-form" novalidate>
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <div class="field">
            <label asp-for="Input.Alias"></label>
            <input asp-for="Input.Alias" autocomplete="off" placeholder="summer-sale" />
            <small>Use 3 to 40 lowercase characters with letters, numbers, hyphens, or underscores.</small>
            <span asp-validation-for="Input.Alias" class="field-error"></span>
        </div>

        <div class="field">
            <label asp-for="Input.TargetUrl"></label>
            <input asp-for="Input.TargetUrl" autocomplete="off" placeholder="https://example.com/campaign" />
            <small>Only valid absolute URLs are accepted.</small>
            <span asp-validation-for="Input.TargetUrl" class="field-error"></span>
        </div>

        <button type="submit" class="primary-button">Create redirect</button>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.CreatedRedirectUrl))
    {
        <section class="result-card" aria-live="polite">
            <p class="result-label">Redirect created</p>
            <a href="@Model.CreatedRedirectUrl" class="result-url">@Model.CreatedRedirectUrl</a>
            <p class="result-note">
                The redirect has been validated and persisted by the backend.
            </p>
        </section>
    }
</section>
