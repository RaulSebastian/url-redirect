@page
@model UrlRedirect.Web.Pages.IndexModel
@{
    ViewData["Title"] = "URL Redirect";
}

<div class="intro">
    <p class="eyebrow">RedirectApp <span class="version-badge">v1.0.0</span></p>
    <h1>url redirect</h1>
    <p class="lede">Public entry point for your redirect service. Admin users sign in with Microsoft Entra ID to create and manage short links.</p>
</div>

<div class="card">
    <h2>Protected admin workspace</h2>
    <p class="lede card-copy">Use the admin console to create redirects. The admin route is protected by Microsoft Entra ID and the app's `AdminOnly` authorization policy.</p>
    <div class="actions">
        <a href="/admin" class="button-primary">Open admin</a>
        <a href="/auth/login?returnUrl=/admin" class="button-secondary">Sign in with Microsoft</a>
    </div>
</div>
