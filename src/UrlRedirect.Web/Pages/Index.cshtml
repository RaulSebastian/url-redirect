@page
@model UrlRedirect.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Create redirect";
}

<section class="hero">
    <div class="hero-copy">
        <p class="eyebrow">RedirectApp</p>
        <h1>URL Redirect</h1>
        <p class="lead">
            Create a short redirect in seconds.
        </p>
    </div>
</section>

<section class="panel">
    <div class="panel-header">
        <h2>New redirect</h2>
    </div>

    <form id="redirect-form" class="redirect-form" novalidate>
        <div id="validation-summary" class="validation-summary" hidden></div>

        <div class="field">
            <label for="alias">Custom alias</label>
            <input id="alias" name="alias" autocomplete="off" placeholder="summer-sale" pattern="^[a-z0-9][a-z0-9-_]{2,39}$" required />
            <small>Use 3 to 40 lowercase characters with letters, numbers, hyphens, or underscores.</small>
            <span id="alias-error" class="field-error"></span>
        </div>

        <div class="field">
            <label for="target-url">Target URL</label>
            <input id="target-url" name="targetUrl" type="url" autocomplete="off" placeholder="https://example.com/campaign" required />
            <small>Only valid absolute URLs are accepted.</small>
            <span id="target-url-error" class="field-error"></span>
        </div>

        <button type="submit" id="submit-button" class="primary-button">Create redirect</button>
    </form>

    <section id="result-card" class="result-card" aria-live="polite" hidden>
        <p class="result-label">Redirect created</p>
        <a id="result-url" href="#" class="result-url"></a>
        <p class="result-note">
            The redirect has been validated and persisted by the backend.
        </p>
    </section>
</section>

@section Scripts {
    <script src="~/js/site.js" asp-append-version="true"></script>
}
