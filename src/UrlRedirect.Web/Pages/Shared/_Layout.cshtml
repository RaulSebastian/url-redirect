<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | URL Redirect</title>
    <link rel="stylesheet" href="/ui/assets/site.css" asp-append-version="true" />
</head>
<body>
    <div class="page-shell">
        <header class="site-header">
            <a href="/ui" class="brand">URL Redirect</a>
            <span class="badge">Frontend MVP</span>
        </header>

        <main class="content">
            @RenderBody()
        </main>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
