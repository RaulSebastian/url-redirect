<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | URL Redirect</title>
    <link rel="stylesheet" href="/ui/assets/site.css" asp-append-version="true" />
</head>
<body>
    <div class="shell">
        @RenderBody()
        <footer class="shell-footer">
            © Copyright <a href="https://raulschnelzer.de" class="footer-sig" target="_blank" rel="noopener">Raul Schnelzer</a> @DateTime.UtcNow.Year. All rights reserved.
        </footer>
    </div>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
